@{
    ViewData["Title"] = "Home";
    bool isAuthenticated = User.Identity?.IsAuthenticated ?? false;
}

<div class="text-center">
    <h1>az204-entra</h1>
    <p>ASP.NET Core 8 web app using Microsoft Entra ID authentication.</p>

    @if (isAuthenticated)
    {
        <p><strong>Welcome, @User.Identity?.Name</strong></p>
        <p><a href="/Home/Profile">View profile page</a></p>
        <p><a href="/MicrosoftIdentity/Account/SignOut">Sign out</a></p>
    }
    else
    {
        <p>You are not signed in.</p>
        <p><a href="/MicrosoftIdentity/Account/SignIn">Sign in with Microsoft Entra ID</a></p>
    }
</div>
