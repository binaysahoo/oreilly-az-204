@{
    ViewData["Title"] = "Secure";
}

<div>
    <h1>Secure page</h1>
    <p>This page requires authentication.</p>
    <p><strong>Name:</strong> @User.Identity?.Name</p>

    <h3>Claims</h3>
    <ul>
        @foreach (var claim in User.Claims)
        {
            <li><strong>@claim.Type</strong>: @claim.Value</li>
        }
    </ul>
</div>
